# Auto detect text files and normalize line endings
* text=auto

# PHP
*.php text

# SQL
*.sql text

# HTML
*.html text

# CSS
*.css text

# JavaScript
*.js text

# Markdown
*.md text

# Git attributes
*.gitattributes text
*.gitignore text

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# SQL
*.sql linguist-language=SQL linguist-detectable=true
